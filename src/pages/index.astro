---
import "../styles/global.css";

/** Row in Now / Previously / Contact: title, URL line, optional explainer copy. */
interface SiteLink {
	href: string;
	label: string;
	explainer?: string;
}

const nowLinks: SiteLink[] = [
	{ href: "https://productjobsanywhere.com/", 
	label: "Solo - Product Jobs Anywhere", 
	explainer: "Making it easier for Product Managers, Designers, and Engineers to find fully remote jobs"},
	
	{
		href: "https://tamfinlay.com/",
		label: "Solo - Coach for Product Managers",
		explainer: "Expert coaching for Product Managers",
	},
	
	{
		href: "https://xmp.world/",
		label: "Product Manager - XMP",
		explainer: "Ops platform for scaling telecoms and construction businesses. Seed stage",
	},
];

const previousLinks: SiteLink[] = [

	{
		href: "https://remote.com/",
		label: "Staff Product Manager - Remote",
		explainer: "Making hiring easy and compliant, globally. Series A -> Series C",
	},
	{
		href: "https://farewill.com/make-a-will-online",
		label: "Group Product Manager - Farewill",
		explainer: "Changing the way the world deals with death. Seed -> Series B",
	},

	{
		href: "https://www.kindeo.com/",
		label: "Product Lead - Kindeo",
		explainer: "Video autobiographies for everyone. Seed stage",
	},

	{
		href: "https://www.secretsales.com/",
		label: "Product Mananger - Secret Sales",
		explainer: "Selling fashion, fast. Series A -> Series B",
	},
	
	];

const contactLinks: SiteLink[] = [
	{
		href: "mailto:tambuildsthings@gmail.com?subject=wownicesitebro",
		label: "Email",
	},
	{ href: "https://www.linkedin.com/in/tam-finlay/", label: "LinkedIn" },
	{ href: "https://x.com/tambuildsthings", label: "Twitter" },
	{ href: "https://github.com/tambuildsthings", label: "GitHub" },
	
];

/** Motion, border, shadow, focus — hover fill added per variant. */
const linkButtonShell =
	"font-body block border-2 border-black px-4 py-3 text-base font-semibold shadow-[4px_4px_0_0_#000] transition-all duration-200 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_#000] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black";

const linkButtonHoverPink = "hover:bg-pink-100";

const linkButtonNow = `${linkButtonShell} bg-white ${linkButtonHoverPink}`;
const linkButtonCream = `${linkButtonShell} bg-[#fffef2] ${linkButtonHoverPink}`;
/** Contact grid: full cell width, label only, centred. */
const linkButtonContact = `${linkButtonCream} !flex w-full min-h-[3.25rem] items-center justify-center text-center`;
---

<html lang="en-GB">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Tam Builds Things</title>
		<link rel="preconnect" href="https://fonts.googleapis.com/" />
		<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Faculty+Glyphic&family=Funnel+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="font-body min-h-screen bg-[#ff10f0] text-black antialiased selection:bg-black selection:text-[#ff10f0]"
	>
		<div class="mx-auto max-w-3xl px-4 py-10 md:py-16">
			<!-- Neo-brutalist shell: flat colour, thick rules, hard offset shadows -->
			<header
				class="mb-10 border-4 border-black bg-[#fffef2] p-6 shadow-[10px_10px_0_0_#000] md:p-8"
			>
				<div class="flex flex-col gap-8 md:flex-row md:items-start md:gap-10">
					<!--
						Easter egg: CSS draws the eyes; show/hide on hover is CSS (group-hover).
						Pupil direction needs pointer position — tiny script, rAF-throttled, only while hovering.
					-->
					<div
						id="headshot-easter"
						class="group relative aspect-square w-full max-w-[14rem] shrink-0 overflow-hidden border-4 border-black shadow-[6px_6px_0_0_#000] md:max-w-[15rem]"
					>
						<img
							src="/headshot.png"
							alt="Headshot of Tam Finlay, smiling against a green background."
							class="block h-full w-full object-cover"
							width="240"
							height="240"
							loading="eager"
							fetchpriority="high"
						/>
						<div
							class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-150 group-hover:opacity-100 motion-reduce:group-hover:opacity-0"
							aria-hidden="true"
						>
							<div
								data-googly-socket
								class="absolute top-[32%] left-[58%] aspect-square w-[12%] max-w-[3.25rem] -translate-x-1/2 -translate-y-1/2 rounded-full border-[0.2rem] border-black bg-white shadow-[2px_2px_0_0_rgba(0,0,0,0.35)]"
							>
								<div
									data-googly-pupil
									class="absolute top-1/2 left-1/2 aspect-square w-[42%] rounded-full bg-black ring-1 ring-black/20"
									style="transform: translate(-50%, -50%);"
								/>
							</div>
							<div
								data-googly-socket
								class="absolute top-[33%] left-[74%] aspect-square w-[10%] max-w-[3.25rem] -translate-x-1/2 -translate-y-1/2 rounded-full border-[0.2rem] border-black bg-white shadow-[2px_2px_0_0_rgba(0,0,0,0.35)]"
							>
								<div
									data-googly-pupil
									class="absolute top-1/2 left-1/2 aspect-square w-[42%] rounded-full bg-black ring-1 ring-black/20"
									style="transform: translate(-50%, -50%);"
								/>
							</div>
						</div>
					</div>
					<div class="min-w-0 flex-1 space-y-6">
						<h1
							class="font-heading text-3xl font-normal uppercase leading-[1.05] tracking-tight md:text-4xl"
						>
							Tam Builds Things
						</h1>
						<div class="space-y-3 border-l-4 border-black pl-4">
							
							<p class="text-base leading-relaxed text-black md:text-lg">
								Hiya. I'm Tam.
								</p>
							<p class="text-base leading-relaxed text-black md:text-lg">
							I like building things on the computer. Either alone or in small teams.
							</p>
							
							<p class="text-base leading-relaxed text-black md:text-lg">
							I especially enjoy making things that are helpful, useful, and valuable to other humans and businesses. 
							</p>

							<p class="text-base leading-relaxed text-black md:text-lg">
							In this new world of AI enablement, I am some combo of builder / founder / product person / driver. 
							</p>
						</div>
					</div>
				</div>
			</header>

			<main class="space-y-8">
				<section
					class="border-4 border-black bg-[#cfff5e] p-6 shadow-[10px_10px_0_0_#000] md:p-8"
					aria-labelledby="now-heading"
				>
					<h2
						id="now-heading"
						class="font-heading mb-5 border-b-4 border-black pb-3 text-2xl font-normal uppercase tracking-tight md:text-3xl"
					>
						Now
					</h2>
					<ul class="space-y-3">
						{
							nowLinks.map((item) => (
								<li>
									<a href={item.href} class={linkButtonNow}>
										{item.label}
										<span class="mt-1 block text-sm font-normal opacity-80">{item.href}</span>
										{item.explainer && (
											<span class="mt-2 block text-sm font-normal leading-snug text-black/70">
												{item.explainer}
											</span>
										)}
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<section
					class="border-4 border-black bg-white p-6 shadow-[10px_10px_0_0_#000] md:p-8"
					aria-labelledby="previously-heading"
				>
					<h2
						id="previously-heading"
						class="font-heading mb-5 border-b-4 border-black pb-3 text-2xl font-normal uppercase tracking-tight md:text-3xl"
					>
						Previously
					</h2>
					<ul class="space-y-3">
						{
							previousLinks.map((item) => (
								<li>
									<a href={item.href} class={linkButtonCream}>
										{item.label}
										<span class="mt-1 block text-sm font-normal opacity-80">{item.href}</span>
										{item.explainer && (
											<span class="mt-2 block text-sm font-normal leading-snug text-black/70">
												{item.explainer}
											</span>
										)}
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<section
					class="border-4 border-dashed border-black bg-white p-6 shadow-[10px_10px_0_0_#000] md:p-8"
					aria-labelledby="contact-heading"
				>
					<h2
						id="contact-heading"
						class="font-heading mb-5 border-b-4 border-black pb-3 text-2xl font-normal uppercase tracking-tight md:text-3xl"
					>
						Contact
					</h2>
					<ul class="grid grid-cols-2 gap-3">
						{
							contactLinks.map((item) => (
								<li class="min-w-0">
									<a href={item.href} class={linkButtonContact}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</section>
			</main>
		</div>
		<script>
			(() => {
				const root = document.getElementById("headshot-easter");
				if (!root || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

				const pupils = root.querySelectorAll("[data-googly-pupil]");
				const sockets = root.querySelectorAll("[data-googly-socket]");
				if (pupils.length !== sockets.length || pupils.length === 0) return;

				/** Eye centre + max pupil offset in root-local pixels (refreshed on enter / resize). */
				let geo = [];
				let raf = 0;
				let mx = 0;
				let my = 0;

				function measure() {
					const rr = root.getBoundingClientRect();
					geo = Array.from(sockets).map((socket) => {
						const sr = socket.getBoundingClientRect();
						return {
							cx: sr.left + sr.width / 2 - rr.left,
							cy: sr.top + sr.height / 2 - rr.top,
							max: sr.width * 0.24,
						};
					});
				}

				function tick() {
					raf = 0;
					const rr = root.getBoundingClientRect();
					const px = mx - rr.left;
					const py = my - rr.top;
					pupils.forEach((pupil, i) => {
						const g = geo[i];
						if (!g) return;
						const dx = px - g.cx;
						const dy = py - g.cy;
						const len = Math.hypot(dx, dy) || 1;
						const t = Math.min(len, g.max);
						const nx = (dx / len) * t;
						const ny = (dy / len) * t;
						pupil.style.transform = `translate(-50%, -50%) translate(${nx}px, ${ny}px)`;
					});
				}

				function onMove(e) {
					mx = e.clientX;
					my = e.clientY;
					if (!raf) raf = requestAnimationFrame(tick);
				}

				function onEnter() {
					measure();
					root.classList.add("is-tracking");
					root.addEventListener("mousemove", onMove, { passive: true });
				}

				function onLeave() {
					root.removeEventListener("mousemove", onMove);
					root.classList.remove("is-tracking");
					if (raf) {
						cancelAnimationFrame(raf);
						raf = 0;
					}
					pupils.forEach((p) => {
						p.style.transform = "translate(-50%, -50%) translate(0px, 0px)";
					});
				}

				const ro = new ResizeObserver(() => {
					if (root.classList.contains("is-tracking")) measure();
				});
				ro.observe(root);
				root.addEventListener("mouseenter", onEnter);
				root.addEventListener("mouseleave", onLeave);
			})();
		</script>
	</body>
</html>
